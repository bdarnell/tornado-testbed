# Package checkouts and per-run state aren't source of truth — they're
# regenerated by scripts/setup.sh and scripts/run_all.sh.
/packages/
/logs/
/results/*.txt
# Keep summary.txt committed as a snapshot of the last run.
!/results/summary.txt

# Raw coverage data (SQLite databases, regenerated by run_all.sh).
/coverage/

# Generated HTML reports ARE committed for easy browsing without re-running.
# (coverage_html/ is intentionally not ignored)
